{
    "cli": {
        "version": ">= 18.3.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            },
            "android": {
                "buildType": "apk"
            },
            "channel": "development",
            "env": {
                "EXPO_PUBLIC_BUILD_CHANNEL": "development",
                "EXPO_PUBLIC_DEPRECATED_INTERNAL_BUILD": "false"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "env": {
                "EXPO_PUBLIC_BUILD_CHANNEL": "closed",
                "EXPO_PUBLIC_DEPRECATED_INTERNAL_BUILD": "false"
            }
        },
        "internalMigration": {
            "autoIncrement": true,
            "distribution": "store",
            "android": {
                "buildType": "app-bundle"
            },
            "channel": "internal-migration",
            "env": {
                "EXPO_PUBLIC_BUILD_CHANNEL": "internal",
                "EXPO_PUBLIC_DEPRECATED_INTERNAL_BUILD": "true"
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle"
            },
            "distribution": "store",
            "channel": "production",
            "env": {
                "EXPO_PUBLIC_BUILD_CHANNEL": "closed",
                "EXPO_PUBLIC_DEPRECATED_INTERNAL_BUILD": "false"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "alpha",
                "serviceAccountKeyPath": "./credentials/google/playspace-deca.json",
                "releaseStatus": "completed"
            }
        },
        "internal-testing": {
            "android": {
                "track": "internal",
                "serviceAccountKeyPath": "./credentials/google/playspace-deca.json",
                "releaseStatus": "completed",
                "changesNotSentForReview": true
            }
        }
    }
}
