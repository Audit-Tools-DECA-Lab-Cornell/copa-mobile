{
    "cli": {
        "version": ">= 18.3.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            },
            "android": {
                "buildType": "apk"
            },
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview"
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle"
            },
            "distribution": "store",
            "channel": "production"
        },
        "apkClient": {
            "android": {
                "buildType": "apk"
            },
            "channel": "apkclient"
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "internal",
                "serviceAccountKeyPath": "./playspace-deca.json",
                "releaseStatus": "draft"
            }
        }
    }
}
