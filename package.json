{
    "name": "audit-tools-playspace-mobile",
    "version": "2.0.0-rc.40",
    "private": true,
    "main": "expo-router/entry",
    "scripts": {
        "dev": "bunx expo start --dev-client --tunnel",
        "upgrade:tamagui": "bunx npm-check-updates -u '*tamagui*' '@tamagui/*' && bun install",
        "start": "bunx expo start -c",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "build": "expo export --platform all",
        "build:android": "expo export --platform android",
        "build:ios": "expo export --platform ios",
        "doctor": "npx expo-doctor",
        "test:contract": "node ./scripts/verify_audit_contract.mjs",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --cache",
        "lint:fix": "eslint . --cache --fix",
        "format": "prettier . --write --ignore-unknown",
        "format:check": "prettier . --check --ignore-unknown",
        "i18n:extract": "npx i18next-cli extract --sync-primary",
        "i18n:watch": "npx i18next-cli extract --sync-primary --watch",
        "i18n:check": "npx i18next-cli status",
        "i18n:translate": "python3 scripts/translate_i18n.py",
        "i18n:translate:dry": "python3 scripts/translate_i18n.py --dry-run",
        "i18n:sync": "bun run i18n:extract && python3 scripts/translate_i18n.py",
        "check": "bun run typecheck && bun run lint && bun run format:check",
        "ci:quality": "bun run check && bun run doctor",
        "prepare": "husky"
    },
    "dependencies": {
        "@expo-google-fonts/geist": "^0.4.1",
        "@expo-google-fonts/jetbrains-mono": "^0.4.1",
        "@expo-google-fonts/space-grotesk": "^0.4.1",
        "@legendapp/state": "^2.1.15",
        "@react-navigation/native": "^7.0.14",
        "@shopify/flash-list": "2.0.2",
        "@tamagui/config": "^2.0.0-rc.40",
        "@tamagui/helpers-icon": "2.0.0-rc.40",
        "@tamagui/lucide-icons-2": "^2.0.0-rc.40",
        "@tamagui/sizable-context": "2.0.0-rc.40",
        "@tamagui/toast": "^2.0.0-rc.40",
        "babel-preset-expo": "~55.0.8",
        "burnt": "^0.12.2",
        "expo": "~55.0.14",
        "expo-background-task": "~55.0.15",
        "expo-build-properties": "~55.0.13",
        "expo-constants": "~55.0.13",
        "expo-dev-client": "^55.0.27",
        "expo-file-system": "~55.0.16",
        "expo-font": "~55.0.4",
        "expo-linking": "~55.0.12",
        "expo-localization": "~55.0.13",
        "expo-network": "~55.0.13",
        "expo-print": "~55.0.13",
        "expo-router": "~55.0.12",
        "expo-secure-store": "~55.0.13",
        "expo-sharing": "~55.0.18",
        "expo-splash-screen": "~55.0.17",
        "expo-status-bar": "~55.0.4",
        "expo-system-ui": "~55.0.15",
        "expo-task-manager": "~55.0.14",
        "expo-updates": "~55.0.20",
        "expo-web-browser": "~55.0.14",
        "i18next": "^26.0.4",
        "loglayer": "^9.1.0",
        "patch-package": "^8.0.1",
        "react": "19.2.0",
        "react-i18next": "^16.5.8",
        "react-native": "0.83.4",
        "react-native-maps": "^1.27.2",
        "react-native-mmkv": "^4.3.0",
        "react-native-nitro-modules": "^0.35.2",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.23.0",
        "react-native-svg": "^15.15.4",
        "react-native-worklets": "0.7.2",
        "serialize-error": "^13.0.1",
        "tamagui": "^2.0.0-rc.40",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@tamagui/babel-plugin": "^2.0.0-rc.40",
        "@tamagui/cli": "^2.0.0-rc.40",
        "@types/react": "~19.2.10",
        "@types/react-native": "^0.73.0",
        "eslint": "^9.39.4",
        "eslint-config-expo": "^55.0.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.8.1",
        "typescript": "~5.9.2"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": "prettier --write --ignore-unknown"
    },
    "packageManager": "bun@1.3.9"
}
